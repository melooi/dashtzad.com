# ===== Public site =====
NEXT_PUBLIC_SITE_URL=https://dashtzad.com
# Headless WordPress origin (used for image remotePatterns & canonical building)
NEXT_PUBLIC_WP_URL=https://cms.dashtzad.com

# ===== WooCommerce REST API (server-only) =====
# WooCommerce -> Settings -> Advanced -> REST API -> generate keys (Read access is enough for the storefront)
WOO_API_URL=https://cms.dashtzad.com
WOO_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== WPGraphQL (optional, for richer queries / Rank Math SEO via GraphQL) =====
WP_GRAPHQL_URL=https://cms.dashtzad.com/graphql

# ===== Rank Math headless SEO =====
# REST getHead endpoint base (Rank Math -> General Settings -> Headless CMS Support = ON)
RANKMATH_API_URL=https://cms.dashtzad.com

# ===== On-demand revalidation (ISR) =====
# Shared secret for /api/revalidate webhook called by WP on content change
REVALIDATE_SECRET=change-me-to-a-long-random-string
